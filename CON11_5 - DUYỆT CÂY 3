#include<bits/stdc++.h>
using namespace std;
struct node{
  int data;
  node *left;
  node *right;
  node(int x)
  {
      data=x;
      left=right= NULL;
  }
};
void makeroot(node*root, int a,int b, char c)
{
    if(c=='L') root->left=new node(b);
    else root-> right =new node(b);
}
void insertnode(node *root, int a,int b,char c)
{
    if(root==NULL) return ;
    if(root->data==a)
    {
        makeroot(root,a,b,c);
    }else
    {
        insertnode(root->left,a,b,c);
        insertnode(root->right,a,b,c);
    }
}
void levelOrder(node *root)
{
    queue<node*>q;
    q.push(root);
    cout<<root->data<<" ";
    while(!q.empty())
    {
        node *tmp=q.front();
        q.pop();
        if(tmp->left !=NULL)
        {
            q.push(tmp->left);
            cout<<tmp->left->data<<" ";
        }
        if(tmp->right !=NULL)
        {
            q.push(tmp-> right);
            cout<<tmp->right->data<<" ";
        }
    }
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
    node*root=NULL;
    int n;
    cin>>n;
    for(int i=0;i<n;i++)
    {
        int a,b;
        char c;
        cin>>a>>b>>c;
        if(root==NULL)
        {
            root=new node(a);
            makeroot(root,a,b,c);
        }else{
            insertnode(root,a,b,c);
        }
    }
    levelOrder(root);
    cout<<endl;
}
}
