#include<bits/stdc++.h>
using namespace std;
struct node{
     int data;
     node* left;
     node* right;
     node(int x)
     {
         data=x;
         left=right=NULL;
     }
};
void makeroot(node* root , int a, int b, char c)
{
    if(c=='L') root->left=new node(b);
    else root->right=new node(b);
}
void insertnode(node* root, int a,int b,char c)
{
    if(root==NULL) return;
    if(root->data==a)
    {
        makeroot(root,a,b,c);
    }else
    {
        insertnode(root->left,a,b,c);
        insertnode(root->right,a,b,c);
    }
}
int check;
int bfs(node* root)
{
    queue<node*> q;
    q.push(root);
    while(!q.empty())
    {
        int n=q.size();
        for(int i=0;i<n;i++)
        {
            node* tmp=q.front();
            q.pop();
            if(tmp->left) q.push(tmp->left);
            if(tmp->right) q.push(tmp->right);
            if(tmp->left==NULL&&tmp->right==NULL)
                check=1;
        }
        if(check&&!q.empty())
            return 0;
    }
    return 1;
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        check=0;
        node*root=NULL;
        int n;
        cin>>n;
        for(int i=0;i<n;i++)
        {
            int a,b;
            char c;
            cin>>a>>b>>c;
            if(root==NULL)
            {
                root=new node(a);
                makeroot(root,a,b,c);
            }else
            {
                insertnode(root,a,b,c);
            }
        }
        cout<<bfs(root)<<endl;
    }
}
