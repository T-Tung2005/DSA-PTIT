#include<bits/stdc++.h>
using namespace std;
int a[1005],b[1005],n,k;
int ok;
void nhap()
{
    for(int i=1;i<=k;i++)
    {
        cin>>a[i];
        b[i]=a[i];
    }
}
void sinh()
{
    int i=k;
    while(i>=1&&a[i]==n-k+i)
    {
        i--;
    }
    if(i==0)
    {
        ok=0;
    }else
    {
        a[i]++;
        for(int j=i+1;j<=k;j++)
        {
            a[j]=a[j-1]+1;
        }
    }

}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        cin>>n>>k;
        nhap();
        ok=1;
        sinh();
        int dem=0;
        if(!ok) cout<<k<<endl;
        else
        {
            for(int i=1;i<=k;i++)
            {
                for(int j=1;j<=k;j++)
                {
                    if(a[i]==b[j]) dem++;
                }
            }
            cout<<k-dem<<endl;
        }
    }
}
