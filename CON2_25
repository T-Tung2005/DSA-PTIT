#include<bits/stdc++.h>
using namespace std;
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        int n;
        cin>>n;
        int a[n];
        long long tong=0;
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
            tong+=a[i];
        }
        if(tong&1) cout<<"NO"<<endl;
        else cout<<"YES"<<endl;
    }
}
