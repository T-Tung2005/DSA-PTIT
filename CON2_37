#include<bits/stdc++.h>
using namespace std;
vector<int>ke[100];
int vst[100][100];
int max1=0;
void dfs(int u,int cnt)
{
    max1=max(cnt,max1);
    for(auto x : ke[u])
    {
        if(!vst[u][x]&&!vst[x][u])
        {
            vst[u][x]=vst[x][u]=1;
            dfs(x,cnt+1);
            vst[u][x]=vst[x][u]=0;
        }
    }
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        for(int i=0;i<100;i++)
        {
            ke[i].clear();
        }
        memset(vst,0,sizeof(vst));
        max1=0;
        int n,m;
        cin>>n>>m;
        for(int i=0;i<m;i++)
        {
            int x,y;
            cin>>x>>y;
            ke[x].push_back(y);
            ke[y].push_back(x);
        }
        for(int i=0;i<n;i++)
        {
            dfs(i,0);
        }
        cout<<max1<<endl;
    }
}
