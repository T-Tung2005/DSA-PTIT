#include<bits/stdc++.h>
using namespace std;
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        string s;
        int k;
        cin>>s>>k;
        int n=s.size();
        while(n<k) n*=2;
        while(n-s.size()!=0)
        {
            if(k>n/2)
            {
                k=n/2;
                if(k>1) k--;
                else k/=2;
            }
            n/=2;
        }
        cout<<s[k-1]<<endl;
    }
}
