#include <bits/stdc++.h>
using namespace std;
bool cmp(pair<int,int>a,pair<int,int>b)
{
    return a.second<b.second;
}
int main()
{
   int q;
   cin>>q;
   while(q--)
   {
   int n;
   cin>>n;
   int s[n],f[n];
   for(int i=0;i<n;i++) cin>>s[i];
   for(int i=0;i<n;i++) cin>>f[i];
   pair<int,int>v[n];
   for(int i=0;i<n;i++) v[i]={s[i],f[i]};
   sort(v,v+n,cmp);
   int k=v[0].second;
   int dem=1;
   for(int i=1;i<n;i++)
   {
       if(v[i].first>=k)
       {
           dem++;
           k=v[i].second;
       }
   }
   cout<<dem<<endl;
   }
}
