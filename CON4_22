#include<bits/stdc++.h>
using namespace std;
int timkiem(int a[],int n,int x)
{
    int l=0;
    int r=n-1;
    int res=-1;
    while(l<=r)
    {
        int mid=(l+r)/2;
        if(a[mid]==x)
        {
            res=mid;
            break;
        }else if(a[mid]<x)
        {
            l=mid+1;
        }else
        {
            r=mid-1;
        }
    }
    return res;
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        int n,m;
        cin>>n>>m;
        int a[n+1];
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }
        int k=timkiem(a,n,m);
        if(k==-1)
        {
            cout<<"NO"<<endl;
        }else
        {
            cout<<k+1<<endl;
        }
    }

}
