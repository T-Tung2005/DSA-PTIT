#include<bits/stdc++.h>
using namespace std;
const int mod=123456789;
long long binpow(int n , long long k)
{
    if(k==0) return 1;
    long long x=binpow(n,k/2);
    if(k%2==0) 
        return (x*x)%mod;
    else 
        return ((x*x%mod)*n%mod)%mod;
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        long long n;
        cin>>n;
        cout<<binpow(2,n-1)<<endl;
    }
}
