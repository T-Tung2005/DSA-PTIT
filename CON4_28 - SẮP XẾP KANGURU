#include<bits/stdc++.h>
using namespace std;
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        int n;
        cin>>n;
        int a[n];
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }
        sort(a,a+n);
        int i=0,j=n/2;
        int dem=0;
        while(i<n/2&&j<n)
        {
            if(a[j]>=2*a[i])
            {
                dem++;
                i++;
                j++;
            }else
            {
                j++;
            }
        }
        cout<<n - dem<<endl;
    }
}
