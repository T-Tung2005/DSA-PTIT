#include<bits/stdc++.h>
using namespace std;
long long timkiem(int a[], int n, int x) // tìm phần tử đầu tiên lớn hơn x
{
    int res=-1;
    int l=0;
    int r=n-1;
    while(l<=r)
    {
        int mid=(l+r)/2;
       if(a[mid]==x)
       {
           res=mid;
           l=mid+1;
       }else if (a[mid]<x)
       {
           l=mid+1;
       }else {
       r=mid-1;
       }
    }
    return res;
}
int main()
{
    int t;
    cin>>t;
    while(t--)
    {
        int n;
        cin>>n;
        int a[n];
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }
        long long k=timkiem(a,n,0);
        cout<<k+1<<endl;
    }
}
