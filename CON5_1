#include <bits/stdc++.h>
using namespace std;
int dp[100][100];
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
   string s1,s2;
   cin>>s1>>s2;
   int k=s1.size();
   int h=s2.size();
   for(int i=1;i<=k;i++)
   {
       for(int j=1;j<=h;j++)
       {
           if(s1[i-1]==s2[j-1])
           {
               dp[i][j]=dp[i-1][j-1]+1;
           }else
           {
               dp[i][j]=max(dp[i-1][j],dp[i][j-1]);
           }
       }
   }
   cout<<dp[k][h]<<endl;
    }
}
