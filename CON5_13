#include<bits/stdc++.h>
using namespace std;
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
    int n;
    cin>>n;
    vector<int>ugly(n);
    ugly[0]=1;
    int i2=0,i3=0,i5=0;
    for(int i=1;i<n;i++)
    {
        int tmp=min({ugly[i2]*2,ugly[i3]*3,ugly[i5]*5});
        ugly[i]=tmp;
        if(tmp==ugly[i2]*2) i2++;
        if(tmp==ugly[i3]*3) i3++;
        if(tmp==ugly[i5]*5) i5++;
    }
    cout<<ugly[n-1]<<endl;
}
}
