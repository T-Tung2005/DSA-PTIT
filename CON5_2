#include<bits/stdc++.h>
using namespace std;
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        int n;
        cin>>n;
        int a[n];
        for(int i=1;i<=n;i++)
        {
            cin>>a[i];
        }
        vector<int>dp(n+1);
        for(int i=1;i<=n;i++)
        {
            dp[i]=1;
            for(int j=1;j<=i;j++)
            {
                if(a[i]>a[j]){
                dp[i]=max(dp[i],dp[j]+1);
                }
            }
        }
        sort(dp.begin(),dp.end(),greater<int>());
        cout<<dp[0]<<endl;
    }
}
