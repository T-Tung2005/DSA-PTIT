#include<bits/stdc++.h>
using namespace std;
string s;
vector<int>v;
void bfs(int h)
{
        int tmp=s[h]-'0';
        v.push_back(tmp);
        for(int i=h+1;i<s.size();i++)
        {
            tmp=(tmp*10+(s[i]-'0'));
            v.push_back(tmp);
        }
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        cin>>s;
        v.clear();
        for(int i=0;i<s.size();i++)
        {
            bfs(i);
        }
        long long tong=0;
        for(auto x : v)
        {
            tong+=x;
        }
        cout<<tong<<endl;
    }
}
