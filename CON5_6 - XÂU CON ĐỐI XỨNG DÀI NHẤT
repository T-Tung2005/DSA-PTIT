#include<bits/stdc++.h>
using namespace std;
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
    string s;
    cin>>s;
    int n=s.size();
    long long f[n+1][n+1];
    memset(f, 0, sizeof(f));
    for(int i=1;i<=n;i++)
    {
        f[i][i]=1;
    }
    s="x"+s;
    int ans=1;
    for(int len=2;len<=n;len++)
    {
        for(int i=1;i<=n-len+1;i++)
        {
            int j=i+len-1;
            if(len==2&&s[i]==s[j]) f[i][j]=1;
            else
                f[i][j]=f[i+1][j-1]&& (s[i]==s[j]);
             if(f[i][j]==1) ans=max(ans,len);
        }
    }
    cout<<ans<<endl;
    }
}
