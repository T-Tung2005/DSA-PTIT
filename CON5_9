#include<bits/stdc++.h>
using namespace std;
const int mod=1e9+7;
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        int n,k;
        cin>>n>>k;
        long long dp[105][50005]={0};
        dp[0][0]=1;//N chữ số tổng là K
        //0 chữ số tổng là 0;
        //số cách tạo i chữ số có tổng bằng k;
        for(int i=1;i<=n;i++)
        {
            for(int j=0;j<=k;j++)
            {
                for(int h=0;h<=9;h++)
                {
                    if(j>=h)
                    {
                        dp[i][j]+=dp[i-1][j-h];
                        dp[i][j]%=mod;
                    }
                }
            }
        }
        long long tmp=0;
        for(int first=1;first<=9;first++)
        {
            if(k>=first)
            {
                tmp+=dp[n-1][k-first];
                tmp%=mod;
            }
        }
        cout<<tmp<<endl;
    }
}
