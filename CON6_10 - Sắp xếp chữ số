#include<bits/stdc++.h>
using namespace std;
bool visited[1000];
set<int>se;
void tach(long long n)
{
    while(n!=0)
    {
        int r=n%10;
        visited[r]=1;
        n/=10;
    }
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        memset(visited,0,sizeof(visited));
        int n;
        cin>>n;
        int a[n+1];
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
            tach(a[i]);
        }
        for(int i=0;i<=9;i++)
        {
            if(visited[i])
            {
                cout<<i<<" ";
            }
        }
        cout<<endl;
    }
}
