#include<bits/stdc++.h>
using namespace std;
bool cmp(pair<int,int>a,pair<int,int>b)
{
    if(a.first==b.first)
        return a.second<b.second;
    return a.first<b.first;
}
int main()
{
   int q;
   cin>>q;
   while(q--)
   {
       int n,k;
       cin>>n>>k;
       vector<int>v(n);
       int tmp=0;
       vector<pair<int,int>>v1;
       for(int i=0;i<n;i++)
       {
           cin>>v[i];
           tmp=k-v[i];
           v1.push_back({abs(tmp),i});
       }
       sort(v1.begin(),v1.end(),cmp);
       for(auto x : v1)
       {
           cout<<v[x.second]<<" ";
       }
       cout<<endl;
        v1.clear();
   }
}
