#include<bits/stdc++.h>
using namespace std;
int timkiem(int a[],int n, int x)
{
    int l=0;
    int r=n-1;
    while(l<=r)
    {
        int mid=(l+r)/2;
        if(a[mid]==x) return mid;
        if(a[l]<=a[mid])
        {
            if(a[l]<=x && x<a[mid])
                r=mid-1;
            else
                l=mid+1;
        }else
        {
            if(a[mid]<x&&x<=a[r])
                l=mid+1;
            else
                r=mid-1;
        }
    }
    return -1;
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        int n,k;
        cin>>n>>k;
        int a[n];
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }
        cout<<timkiem(a,n,k)+1<<endl;
    }
}
