#include<bits/stdc++.h>
using namespace std;
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
    int n;
    cin>>n;
    int a[n];
    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }
    int l=0,r=n-1;
   while(l<n-1&&a[l]<=a[l+1])
   {
       l++;
   }
   if(l==n-1)
   {
       cout<<"-1"<<endl;
       continue;
   }
   while(r>0&&a[r]>a[r-1])
   {
       r--;
   }
   int m=a[l],k=a[l];
   for(int i=l;i<=r;i++)
   {
       if(a[i]<m) m=a[i];
       if(a[i]>k) k=a[i];
   }
   for(int i=0;i<l;i++)
   {
       if(a[i]>m)
       {
           l=i;
           break;
       }
   }
   for(int i=n-1;i>r;i--)
   {
       if(a[i]<k)
       {
           r=i;
           break;
       }
   }
   cout<<l+1<<" "<<r+1<<endl;
    }
}
