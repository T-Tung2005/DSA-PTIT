#include<bits/stdc++.h>
using namespace std;
int maxsize(string s)
{
    stack<int>st;
     st.push(-1);//trường hợp ngoại lệ rỗng
     int n=s.size();
     int res=0;
     for(int i=0;i<n;i++)
     {
         if(s[i]=='(')
         {
             st.push(i);
         }else{
            st.pop();
            if(st.empty())
            {
                st.push(i);
            }else
            {
               res=max(res,i-st.top());
            }
         }
     }
     return res;
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        string s;
        cin>>s;
        cout<<maxsize(s)<<endl;
    }
}
