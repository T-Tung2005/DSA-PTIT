#include<bits/stdc++.h>
using namespace std;
string biendoi(string s)
{
    int n=s.size();
    stack<int>st;
    string res="";
    st.push(1);
    for(int i=0;i<n;i++)
    {
        if(s[i]=='(')
        {
            if(i>0 &&s[i-1]=='-')
            {
                st.push(-st.top());
            }else
            {
                st.push(st.top());
            }
        }else if(s[i]==')')
        {
            st.pop();
        }else if(s[i]=='+')
        {
            if(st.top()==1)
            {
                res+='+';
            }else{
                res+='-';
            }
        }else if(s[i]=='-')
        {
            if(st.top()==1)
            {
                res+="-";
            }else{
                res+="+";
            }
        }else
        {
            res+=s[i];
        }
    }
    return res;
}
int main()
{
    int q;
    cin>>q;
    cin.ignore();
    while(q--)
    {
        string s;
        cin>>s;
        cout<<biendoi(s)<<endl;
    }
}
