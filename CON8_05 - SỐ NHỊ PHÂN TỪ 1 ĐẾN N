#include<bits/stdc++.h>
using namespace std;
int chuyendoi(long long n)
{
    string s=to_string(n);
    long long tong=0;
    for(int i=0;i<s.size();i++)
    {
        tong=tong*2+(s[i]-'0');
    }
    return tong;
}
int n;
void bfs(int u)
{
    queue<int>q;
    q.push(1);
    while(!q.empty())
    {
        int tmp=q.front();
        q.pop();
        if(chuyendoi(tmp)<=n)
        {
            cout<<tmp<<" ";
            q.push(tmp*10);
            q.push(tmp*10+1);
        }
    }
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        cin>>n;
        bfs(n);
        cout<<endl;
    }
}
