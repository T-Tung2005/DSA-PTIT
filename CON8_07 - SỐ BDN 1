#include<bits/stdc++.h>
using namespace std;
vector<int>v;
void bfs(int n)
{
    queue<int>q;
    q.push(1);
    while(!q.empty())
    {
        int tmp=q.front();
        q.pop();
        if(tmp<=n)
        {
            v.push_back(tmp);
        }else
        {
            break;
        }
        q.push(tmp*10);
        q.push(tmp*10+1);
    }
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        v.clear();
        int n;
        cin>>n;
        bfs(n);
        cout<<v.size()<<endl;
    }
}
