#include<bits/stdc++.h>
using namespace std;
int dem[10];
bool kiemtra(int n)
{
    memset(dem,0,sizeof(dem));
    if(n==0) return true;
    while(n!=0)
    {
        int r=n%10;
        if(r>5) return false;
        if(dem[r]==1) return false;
        dem[r]++;
        n/=10;
    }
    return true;
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        int dem1=0;
        int l,r;
        cin>>l>>r;
        for(int i=l;i<=r;i++)
        {
            if(kiemtra(i))
            {
                dem1++;
            }
        }
        cout<<dem1<<endl;
    }
}
