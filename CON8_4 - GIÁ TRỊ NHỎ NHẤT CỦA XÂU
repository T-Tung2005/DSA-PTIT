#include<bits/stdc++.h>
using namespace std;
int dem[1000];
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        long long tong=0;
        string s;
        int k;
        cin>>k>>s;
        memset(dem,0,sizeof(dem));
        priority_queue<int>Q;
        int n=s.size();
        for(char x : s)
        {
            dem[x]++;
        }
        for(int i=0;i<=256;i++)
        {
            if(dem[i]>0)
            {
                Q.push(dem[i]);
            }
        }
        while(k--)
        {
            int tmp=Q.top();
            Q.pop();
            tmp--;
            Q.push(tmp);
        }
       while(!Q.empty())
       {
           int tmp=Q.top();
            Q.pop();
           tong+=tmp*tmp;
       }
       cout<<tong<<endl;
    }
}
