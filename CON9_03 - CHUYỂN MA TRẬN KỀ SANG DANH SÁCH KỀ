#include<bits/stdc++.h>
using namespace std;
int main()
{
    int n;
    cin>>n;
    int a[100][100];
    for(int i=1;i<=n;i++)
    {
        for(int j=1;j<=n;j++)
        {
            cin>>a[i][j];
        }
    }
    vector<int>ke[1000];
    for(int i=1;i<=n;i++)
    {
        for(int j=1;j<=n;j++)
        {
            if(a[i][j]==1)
            {
                ke[i].push_back(j);
            }
        }
    }
    for(int i=1;i<=n;i++)
    {
        for(auto x : ke[i])
        {
            cout<<x<<" ";
        }
        cout<<endl;
    }
}
