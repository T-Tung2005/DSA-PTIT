#include<bits/stdc++.h>
using namespace std;
vector<int>ke[1000];
int euler(int u)
{
    int cnt=0;
    for(int i=1;i<=u;i++)
    {
        if(ke[i].size()& 1) cnt++;
    }
    if(cnt==2) return 1;
    if(cnt==0) return 2;
    return 0;
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        int n,m;
        cin>>n>>m;
        for(int i=0;i<m;i++)
        {
            int x,y;
            cin>>x>>y;
            ke[x].push_back(y);
            ke[y].push_back(x);
        }
        cout<<euler(n)<<endl;
    }
}
