#include<bits/stdc++.h>
using namespace std;
int vst[1005][1005];
int euler(int u)
{
    for(int i=1;i<=u;i++)
    {
        int x=0,y=0;
        for(int j=1;j<=u;j++)
        {
            if(vst[i][j]) x++;
            if(vst[j][i]) y++;
        }
        if(x!=y) return 0;
    }
    return 1;
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        int n,m;
        cin>>n>>m;
        while(m--)
        {
            int x,y;
            cin>>x>>y;
            vst[x][y]=1;
        }
        cout<<euler(n)<<endl;
    }
}
