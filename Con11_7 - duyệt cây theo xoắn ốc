#include<bits/stdc++.h>
using namespace std;
struct node{
  int data;
  node *left;
  node *right;
  node(int x)
  {
      data=x;
      left=right= NULL;
  }
};
void makeroot(node*root, int a,int b, char c)
{
    if(c=='L') root->left=new node(b);
    else root-> right =new node(b);
}
void insertnode(node *root, int a,int b,char c)
{
    if(root==NULL) return ;
    if(root->data==a)
    {
        makeroot(root,a,b,c);
    }else
    {
        insertnode(root->left,a,b,c);
        insertnode(root->right,a,b,c);
    }
}
void xoanoc(node*root)
{
    stack<node*>s1,s2;
    s1.push(root);
    while(!s1.empty()||!s2.empty())
    {
        while(!s1.empty())
        {
            node *top1=s1.top();s1.pop();
            cout<<top1->data<<" ";
            if(top1->right !=NULL)
            {
                s2.push(top1->right);
            }
            if(top1->left !=NULL)
            {
                s2.push(top1->left);
            }
        }
        while(!s2.empty())
        {
            node *top1=s2.top();s2.pop();
            cout<<top1->data<<" ";
            if(top1->left !=NULL)
            {
                s1.push(top1->left);
            }
            if(top1->right !=NULL)
            {
                s1.push(top1->right);
            }
        }
    }
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
    node*root=NULL;
    int n;
    cin>>n;
    for(int i=0;i<n;i++)
    {
        int a,b;
        char c;
        cin>>a>>b>>c;
        if(root==NULL)
        {
            root=new node(a);
            makeroot(root,a,b,c);
        }else{
            insertnode(root,a,b,c);
        }
    }
    xoanoc(root);
    cout<<endl;
}
}
