#include<bits/stdc++.h>
using namespace std;
struct node
{
   int data;
   node* left;
   node* right;
   node(int x)
   {
       data=x;
       left=right=NULL;
   }
};
node* insertnode(vector<int>v,int i,int n)
{
    if(i>=n||v[i]==-1) return NULL;
    node* tmp=new node(v[i]);
    tmp->left=insertnode(v,2*i+1,n);
    tmp->right=insertnode(v,2*i+2,n);
    return tmp;
}
int dem=0;
int tongnut(node* root)
{
    if(root==NULL) return 0;
    return 1+tongnut(root->left)+tongnut(root->right);
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    dem=0;
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    node * root;
    root=insertnode(v,0,n);
    cout<<tongnut(root)<<endl;
}
