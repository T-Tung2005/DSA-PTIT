#include<bits/stdc++.h>
using namespace std;
struct node
{
    int data;
    node* left;
    node* right;
    node(int x)
    {
        data=x;
        left=right=NULL;
    }
};
node* buildTree(vector<int> a){
	if(a.empty() && a[0] == -1) return NULL;
	node* root = new node(a[0]);
	queue<node*> q;
	q.push(root);
	int i = 1, n = a.size();
	while(i < n){
		node* current = q.front(); q.pop();
		if(i < n && a[i] != -1){
			current->left = new node(a[i]);
			q.push(current->left);
		}
		i++;
		if(i < n && a[i] != -1){
			current->right = new node(a[i]);
			q.push(current->right);
		}
		i++;
	}
	return root;
}
int tongnut(node* root)
{
    if(root==NULL) return 0;
    return root->data+tongnut(root->left)+tongnut(root->right);
}
int main()
{
    string s;
    getline(cin,s);
    stringstream ss(s);
    vector<int>v;
    int tmp;
    while(ss>>tmp)
        v.push_back(tmp);
    node* root;
    root=buildTree(v);
    cout<<tongnut(root)<<endl;
}
